{{- $items := slice -}}
{{- range .RegularPages.ByWeight.ByTitle -}}
  {{- $itemDates := partial "effective-dates.html" . -}}
  {{- $items = $items | append (dict
    "title" .Title
    "url" .Permalink
    "summary" (.Summary | plainify)
    "content" (.Plain | plainify)
    "lastmod" $itemDates.modifiedISO
    "section" .Section
    "tags" (default (slice) .Params.tags)
  ) -}}
{{- end -}}

{{- $sectionDates := partial "effective-dates.html" . -}}
{{- dict
  "title" .Title
  "url" .Permalink
  "summary" (.Summary | plainify)
  "content" (.Plain | plainify)
  "lastmod" $sectionDates.modifiedISO
  "section" .Section
  "tags" (default (slice) .Params.tags)
  "items" $items
| jsonify -}}
