{{- $sections := slice -}}
{{- range .Site.Sections.ByWeight.ByTitle -}}
  {{- $sectionDates := partial "effective-dates.html" . -}}
  {{- $sections = $sections | append (dict
    "title" .Title
    "url" .Permalink
    "summary" (.Summary | plainify)
    "content" (.Plain | plainify)
    "lastmod" $sectionDates.modifiedISO
    "section" .Section
    "tags" (default (slice) .Params.tags)
  ) -}}
{{- end -}}

{{- $pages := slice -}}
{{- range .Site.RegularPages.ByWeight.ByTitle -}}
  {{- $pageDates := partial "effective-dates.html" . -}}
  {{- $pages = $pages | append (dict
    "title" .Title
    "url" .Permalink
    "summary" (.Summary | plainify)
    "content" (.Plain | plainify)
    "lastmod" $pageDates.modifiedISO
    "section" .Section
    "tags" (default (slice) .Params.tags)
  ) -}}
{{- end -}}

{{- $homeDates := partial "effective-dates.html" .Site.Home -}}
{{- dict
  "title" .Site.Title
  "url" .Site.BaseURL
  "summary" (.Site.Params.description | default "")
  "content" ""
  "lastmod" $homeDates.modifiedISO
  "section" "home"
  "tags" (slice)
  "sections" $sections
  "pages" $pages
| jsonify -}}
