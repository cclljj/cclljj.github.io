{{- $sections := slice -}}
{{- range .Site.Sections.ByWeight.ByTitle -}}
  {{- $sections = $sections | append (dict
    "title" .Title
    "url" .Permalink
    "summary" (.Summary | plainify)
    "content" (.Plain | plainify)
    "lastmod" (.Lastmod.Format "2006-01-02T15:04:05Z07:00")
    "section" .Section
    "tags" (default (slice) .Params.tags)
  ) -}}
{{- end -}}

{{- $pages := slice -}}
{{- range .Site.RegularPages.ByWeight.ByTitle -}}
  {{- $pages = $pages | append (dict
    "title" .Title
    "url" .Permalink
    "summary" (.Summary | plainify)
    "content" (.Plain | plainify)
    "lastmod" (.Lastmod.Format "2006-01-02T15:04:05Z07:00")
    "section" .Section
    "tags" (default (slice) .Params.tags)
  ) -}}
{{- end -}}

{{- dict
  "title" .Site.Title
  "url" .Site.BaseURL
  "summary" (.Site.Params.description | default "")
  "content" ""
  "lastmod" (.Site.Home.Lastmod.Format "2006-01-02T15:04:05Z07:00")
  "section" "home"
  "tags" (slice)
  "sections" $sections
  "pages" $pages
| jsonify -}}
