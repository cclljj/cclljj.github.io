{{- $ordered := slice -}}
{{- $used := dict -}}
{{- $preferred := slice "journal" "conference" "posters" "chapters" "trs" "patents" -}}
{{- range $preferred -}}
  {{- with $.GetPage (printf "/publications/%s" .) -}}
    {{- $ordered = $ordered | append . -}}
    {{- $used = merge $used (dict .File.ContentBaseName true) -}}
  {{- end -}}
{{- end -}}
{{- range .Pages.ByWeight.ByTitle -}}
  {{- if not (index $used .File.ContentBaseName) -}}
    {{- $ordered = $ordered | append . -}}
  {{- end -}}
{{- end -}}

{{- $categories := slice -}}
{{- range $ordered -}}
  {{- $anchor := cond .File (printf "category-%s" .File.ContentBaseName) (printf "category-%s" (urlize .Title)) -}}
  {{- $categories = $categories | append (dict
    "title" .Title
    "anchor" $anchor
    "source_url" .Permalink
    "weight" .Weight
    "summary" (.Summary | plainify)
    "content" (.Plain | plainify)
  ) -}}
{{- end -}}

{{- dict
  "title" .Title
  "url" .Permalink
  "summary" (.Summary | plainify)
  "content" (.Plain | plainify)
  "lastmod" (.Lastmod.Format "2006-01-02T15:04:05Z07:00")
  "section" .Section
  "tags" (default (slice) .Params.tags)
  "categories" $categories
| jsonify -}}
