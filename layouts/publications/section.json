{{- $categories := slice -}}
{{- range .Pages.ByWeight.ByTitle -}}
  {{- $anchor := cond .File (printf "category-%s" .File.ContentBaseName) (printf "category-%s" (urlize .Title)) -}}
  {{- $categories = $categories | append (dict
    "title" .Title
    "anchor" $anchor
    "source_url" .Permalink
    "weight" .Weight
    "summary" (.Summary | plainify)
    "content" (.Plain | plainify)
  ) -}}
{{- end -}}

{{- dict
  "title" .Title
  "url" .Permalink
  "summary" (.Summary | plainify)
  "content" (.Plain | plainify)
  "lastmod" (.Lastmod.Format "2006-01-02T15:04:05Z07:00")
  "section" .Section
  "tags" (default (slice) .Params.tags)
  "categories" $categories
| jsonify -}}
